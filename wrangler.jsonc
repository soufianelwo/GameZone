{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "Jeuxgratuits",
  "compatibility_date": "2026-05-08",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [ "/game/*" ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}